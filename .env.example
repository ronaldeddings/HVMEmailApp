# Google Cloud service account key (paste the full JSON contents)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Google Pub/Sub topic for Gmail notifications
# Format: projects/{project-id}/topics/{topic-name}
GOOGLE_PUBSUB_TOPIC=projects/hvm-email-app/topics/gmail-notifications

# Your Google Workspace domain
GOOGLE_WORKSPACE_DOMAIN=hackervalley.com

# Server port
PORT=3000

# Directory to save captured email JSON files
CAPTURE_DIR=./captured
